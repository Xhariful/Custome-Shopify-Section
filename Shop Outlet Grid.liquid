{%- style -%}
  #store-grid-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }
  .sg-container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .sg-header {
    text-align: {{ section.settings.heading_alignment }};
    margin-bottom: clamp(24px, 5vw, 48px);
  }
  .sg-title {
    font-size: clamp(24px, 4vw, {{ section.settings.title_size }}px);
    font-weight: 700;
    color: {{ section.settings.title_color }};
    margin: 0;
    line-height: 1.2;
  }
  .sg-grid {
    display: grid;
    gap: {{ section.settings.card_gap }}px;
    /* রেসপন্সিভ গ্রিড: মোবাইলে ১টি, ট্যাবে ২টি, ডেক্সটপে ৩টি */
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }
  @media screen and (min-width: 550px) {
    .sg-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media screen and (min-width: 990px) {
    .sg-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }

  .sg-card {
    background: {{ section.settings.card_bg }};
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .sg-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.1);
  }
  .sg-img-wrap {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: #f0f0f0;
    
    {%- if section.settings.img_ratio == 'square' -%}
      aspect-ratio: 1 / 1;
    {%- elsif section.settings.img_ratio == 'portrait' -%}
      aspect-ratio: 3 / 4;
    {%- elsif section.settings.img_ratio == 'landscape' -%}
      aspect-ratio: 16 / 9;
    {%- else -%}
      aspect-ratio: 4 / 3;
    {%- endif -%}
  }
  .sg-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .sg-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e0e0e0;
    color: #666;
  }
  .sg-body {
    padding: clamp(16px, 3vw, 24px);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    text-align: center;
  }
  .sg-card-title {
    font-size: clamp(16px, 2.5vw, {{ section.settings.card_title_size }}px);
    font-weight: 600;
    color: {{ section.settings.card_text_color }};
    margin: 0 0 16px 0;
    line-height: 1.3;
  }
  .sg-btn-wrap {
    margin-top: auto;
  }
  .sg-direction-btn {
    display: inline-block;
    width: 100%;
    padding: 12px 20px;
    background-color: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_text }};
    border: 1px solid {{ section.settings.btn_bg }};
    border-radius: 4px;
    font-size: clamp(13px, 1.8vw, 15px);
    font-weight: 600;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    box-sizing: border-box;
    transition: background-color 0.3s, color 0.3s, border-color 0.3s;
  }
  .sg-direction-btn:hover {
    background-color: transparent;
    color: {{ section.settings.btn_bg }};
  }

  @media screen and (max-width: 749px) {
    #store-grid-{{ section.id }} {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section id="store-grid-{{ section.id }}">
  <div class="sg-container">
    {%- if section.settings.title != blank -%}
      <div class="sg-header">
        <h2 class="sg-title">{{ section.settings.title }}</h2>
      </div>
    {%- endif -%}

    <div class="sg-grid">
      {%- for block in section.blocks -%}
        <div class="sg-card" {{ block.shopify_attributes }}>
          <div class="sg-img-wrap">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {%- else -%}
              <div class="sg-img-placeholder">
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>
          
          <div class="sg-body">
            <h3 class="sg-card-title">{{ block.settings.title | default: "Store Location" }}</h3>
            {%- if block.settings.direction_url != blank -%}
              <div class="sg-btn-wrap">
                <a href="{{ block.settings.direction_url }}" target="_blank" rel="noopener" class="sg-direction-btn">
                  {{ section.settings.btn_label }}
                </a>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Store Grid",
  "settings": [
    { "type": "header", "content": "Section Heading" },
    { "type": "text", "id": "title", "label": "Section Title", "default": "A Look Inside Our Stores" },
    { "type": "select", "id": "heading_alignment", "label": "Title Alignment", "options": [ { "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" } ], "default": "center" },
    
    { "type": "header", "content": "Global Card Settings" },
    { "type": "select", "id": "img_ratio", "label": "Image Aspect Ratio", "options": [ { "value": "square", "label": "Square (1:1)" }, { "value": "portrait", "label": "Portrait (3:4)" }, { "value": "landscape", "label": "Landscape (16:9)" }, { "value": "standard", "label": "Standard (4:3)" } ], "default": "standard" },
    { "type": "text", "id": "btn_label", "label": "Button Label", "default": "Direction" },
    { "type": "range", "id": "card_gap", "label": "Gap Between Cards (px)", "min": 16, "max": 40, "step": 4, "default": 24 },
    { "type": "range", "id": "card_radius", "label": "Card Corner Radius (px)", "min": 0, "max": 20, "step": 2, "default": 8 },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "#ffffff" },
    { "type": "color", "id": "title_color", "label": "Main Title Color", "default": "#121212" },
    { "type": "color", "id": "card_bg", "label": "Card Background", "default": "#f9f9f9" },
    { "type": "color", "id": "card_text_color", "label": "Card Title Color", "default": "#121212" },
    { "type": "color", "id": "btn_bg", "label": "Button Background Color", "default": "#121212" },
    { "type": "color", "id": "btn_text", "label": "Button Text Color", "default": "#ffffff" },

    { "type": "header", "content": "Typography (Desktop Sizes)" },
    { "type": "range", "id": "title_size", "label": "Main Title Size (px)", "min": 24, "max": 60, "step": 2, "default": 40 },
    { "type": "range", "id": "card_title_size", "label": "Card Title Size (px)", "min": 16, "max": 28, "step": 1, "default": 20 },

    { "type": "header", "content": "Layout Spacing" },
    { "type": "number", "id": "max_width", "label": "Max Container Width (px)", "default": 1200 },
    { "type": "range", "id": "padding_top", "label": "Padding Top (px)", "min": 0, "max": 120, "step": 4, "default": 60 },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom (px)", "min": 0, "max": 120, "step": 4, "default": 60 },
    { "type": "range", "id": "mobile_padding_top", "label": "Mobile Padding Top (px)", "min": 0, "max": 80, "step": 4, "default": 40 },
    { "type": "range", "id": "mobile_padding_bottom", "label": "Mobile Padding Bottom (px)", "min": 0, "max": 80, "step": 4, "default": 40 }
  ],
  "blocks": [
    {
      "type": "store",
      "name": "Store Location",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Store Image" },
        { "type": "text", "id": "title", "label": "Store Name", "default": "Dhaka Outlet" },
        { "type": "url", "id": "direction_url", "label": "Google Map/Direction Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Store Grid",
      "blocks": [
        { "type": "store", "settings": { "title": "Store Location 1" } },
        { "type": "store", "settings": { "title": "Store Location 2" } },
        { "type": "store", "settings": { "title": "Store Location 3" } }
      ]
    }
  ]
}
{% endschema %}