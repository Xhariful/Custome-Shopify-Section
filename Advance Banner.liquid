    { "type": "text", "id": "right_headline", "label": "Headline", "default": "Less Is More" },
    { "type": "textarea", "id": "right_body", "label": "Body Text", "default": "Pure form. Refined lines. The shoe that says everything by saying nothing." },
    { "type": "text", "id": "right_btn_label", "label": "Button Label", "default": "Shop Clean" },
    { "type": "url", "id": "right_btn_url", "label": "Button URL" },
    { "type": "color", "id": "right_bg", "label": "Background Color", "default": "#f5f2ee" },
    { "type": "color", "id": "right_text", "label": "Text Color", "default": "#1a1a1a" },
    { "type": "color", "id": "right_accent", "label": "Eyebrow Color", "default": "#1a1a1a" },
    { "type": "color", "id": "right_btn_bg", "label": "Button BG", "default": "#1a1a1a" },
    { "type": "color", "id": "right_btn_text", "label": "Button Text", "default": "#f5f2ee" },
    { "type": "color", "id": "right_btn_border", "label": "Button Border", "default": "#1a1a1a" },
    { "type": "color", "id": "right_btn_hover_bg", "label": "Button Hover BG", "default": "#f5f2ee" },
    { "type": "color", "id": "right_btn_hover_text", "label": "Button Hover Text", "default": "#1a1a1a" },
