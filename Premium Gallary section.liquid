<style>
  .photo-grid-wrapper-{{ section.id }} {
    width: 100%;
    max-width: 1380px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}rem 1rem {{ section.settings.padding_bottom }}rem 1rem;
    box-sizing: border-box;
  }

  .photo-cards-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  @media (min-width: 640px) {
    .photo-cards-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .photo-cards-grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    }
  }

  .photo-grid-item {
    aspect-ratio: 1 / 1;
    border-radius: {{ section.settings.card_radius }}px;
    display: grid;
    place-items: center;
    font-size: 4.5rem;
    border: 2px solid rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease;
    overflow: hidden;
    position: relative;
    box-sizing: border-box;
    cursor: pointer;
  }

  .photo-grid-item:hover {
    transform: scale(1.05) rotate(-3deg);
  }

  .photo-grid-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .bg-color-0 { background-color: rgba(251, 191, 36, 0.7); }
  .bg-color-1 { background-color: rgba(244, 114, 182, 0.4); }
  .bg-color-2 { background-color: #ffdac1; }
  .bg-color-3 { background-color: #fff9e6; }
  .bg-color-4 { background-color: #baffc9; }

  /* Lightbox Modal */
  .photo-lightbox-modal {
    display: none;
    position: fixed;
    z-index: 99999;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(5px);
    justify-content: center;
    align-items: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .photo-lightbox-modal.active {
    display: flex;
    opacity: 1;
  }

  .lightbox-content-container {
    position: relative;
    width: 90%;
    max-width: 800px;
    height: 80vh;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #LightboxTarget-{{ section.id }} {
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: opacity 0.25s ease-in-out;
    opacity: 1;
  }

  #LightboxTarget-{{ section.id }}.fade-out {
    opacity: 0;
  }

  .lightbox-media {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    border-radius: 12px;
    user-select: none;
  }

  .lightbox-text-fallback {
    font-size: 8rem;
    line-height: 1;
    user-select: none;
    color: #fff;
  }

  /* Control Buttons Without Hover Scale */
  .lightbox-btn {
    position: fixed;
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    border: none;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    font-size: 24px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    user-select: none;
    z-index: 100000;
    transition: background 0.2s ease;
  }

  .lightbox-btn:hover {
    background: rgba(255, 255, 255, 0.25);
    /* Transform/Scale removed */
  }

  .lightbox-close {
    top: 20px;
    right: 20px;
  }

  .lightbox-prev {
    left: 20px;
    top: 50%;
    transform: translateY(-50%);
  }

  .lightbox-next {
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
  }

  /* Responsive Controls for Mobile */
  @media (max-width: 767px) {
    .lightbox-btn {
      width: 44px;
      height: 44px;
      font-size: 20px;
    }
    .lightbox-close {
      top: 15px;
      right: 15px;
    }
    .lightbox-prev {
      left: 15px;
    }
    .lightbox-next {
      right: 15px;
    }
  }
</style>

<section class="photo-grid-wrapper-{{ section.id }}">
  <div class="photo-cards-grid">
    
    {%- for block in section.blocks -%}
      {%- assign color_index = forloop.index0 | modulo: 5 -%}
      
      <div 
        class="photo-grid-item bg-color-{{ color_index }} js-lightbox-trigger" 
        data-index="{{ forloop.index0 }}"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.image != blank -%}
          {%- assign img_url = block.settings.image | image_url: width: 1200 -%}
          <img 
            src="{{ block.settings.image | image_url: width: 400 }}" 
            data-full-src="{{ img_url }}"
            data-type="image"
            loading="lazy" 
            alt="{{ block.settings.emoji_text }}"
          >
        {%- elsif block.settings.emoji_text != blank -%}
          <span data-type="text" data-val="{{ block.settings.emoji_text }}">{{ block.settings.emoji_text }}</span>
        {%- else -%}
          <span data-type="text" data-val="🐶">🐶</span>
        {%- endif -%}
      </div>
    {%- endfor -%}

  </div>
</section>

<div id="PhotoLightbox-{{ section.id }}" class="photo-lightbox-modal" role="dialog" aria-modal="true">
  <button class="lightbox-btn lightbox-close" aria-label="Close Lightbox">&times;</button>
  <button class="lightbox-btn lightbox-prev" aria-label="Previous Photo">&#10094;</button>
  
  <div class="lightbox-content-container">
    <div id="LightboxTarget-{{ section.id }}"></div>
  </div>
  
  <button class="lightbox-btn lightbox-next" aria-label="Next Photo">&#10095;</button>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const sectionId = "{{ section.id }}";
    const modal = document.getElementById(`PhotoLightbox-${sectionId}`);
    const target = document.getElementById(`LightboxTarget-${sectionId}`);
    const triggers = document.querySelectorAll('.js-lightbox-trigger');
    const closeBtn = modal.querySelector('.lightbox-close');
    const prevBtn = modal.querySelector('.lightbox-prev');
    const nextBtn = modal.querySelector('.lightbox-next');
    
    let currentIndex = 0;
    const itemsData = [];

    triggers.forEach((trigger, idx) => {
      const img = trigger.querySelector('img');
      const textSpan = trigger.querySelector('span');
      
      if (img) {
        itemsData.push({
          type: 'image',
          src: img.getAttribute('data-full-src') || img.src,
          alt: img.alt || ''
        });
      } else if (textSpan) {
        itemsData.push({
          type: 'text',
          val: textSpan.getAttribute('data-val') || '🐶'
        });
      } else {
        itemsData.push({
          type: 'text',
          val: '🐶'
        });
      }

      trigger.addEventListener('click', function () {
        currentIndex = idx;
        openLightbox();
      });
    });

    function openLightbox() {
      updateLightboxContent();
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      modal.classList.remove('active');
      document.body.style.overflow = '';
      target.innerHTML = '';
    }

    function updateLightboxContent() {
      target.classList.add('fade-out');

      setTimeout(() => {
        target.innerHTML = '';
        const data = itemsData[currentIndex];

        if (data.type === 'image') {
          const img = document.createElement('img');
          img.src = data.src;
          img.alt = data.alt;
          img.className = 'lightbox-media';
          target.appendChild(img);
        } else {
          const div = document.createElement('div');
          div.className = 'lightbox-text-fallback';
          div.textContent = data.val;
          target.appendChild(div);
        }

        target.classList.remove('fade-out');
      }, 200); 
    }

    function showNext() {
      currentIndex = (currentIndex + 1) % itemsData.length;
      updateLightboxContent();
    }

    function showPrev() {
      currentIndex = (currentIndex - 1 + itemsData.length) % itemsData.length;
      updateLightboxContent();
    }

    closeBtn.addEventListener('click', closeLightbox);
    nextBtn.addEventListener('click', showNext);
    prevBtn.addEventListener('click', showPrev);

    modal.addEventListener('click', function (e) {
      if (e.target === modal || e.target.classList.contains('lightbox-content-container')) {
        closeLightbox();
      }
    });

    document.addEventListener('keydown', function (e) {
      if (!modal.classList.contains('active')) return;
      if (e.key === 'ArrowRight') showNext();
      if (e.key === 'ArrowLeft') showPrev();
      if (e.key === 'Escape') closeLightbox();
    });

    let touchStartX = 0;
    let touchEndX = 0;

    modal.addEventListener('touchstart', function (e) {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    modal.addEventListener('touchend', function (e) {
      touchEndX = e.changedTouches[0].screenX;
      handleSwipe();
    }, { passive: true });

    function handleSwipe() {
      const threshold = 50;
      if (touchEndX < touchStartX - threshold) {
        showNext();
      }
      if (touchEndX > touchStartX + threshold) {
        showPrev();
      }
    }
  });
</script>

{% schema %}
{
  "name": "Interactive Photo Grid",
  "settings": [
    {
      "type": "header",
      "content": "Grid Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 3,
      "max": 6,
      "step": 1,
      "label": "Columns on Desktop",
      "default": 4
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Card Border Radius",
      "default": 24
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 1,
      "max": 8,
      "step": 0.5,
      "unit": "rem",
      "label": "Padding Top",
      "default": 2
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 1,
      "max": 8,
      "step": 0.5,
      "unit": "rem",
      "label": "Padding Bottom",
      "default": 2
    }
  ],
  "blocks": [
    {
      "type": "grid_item",
      "name": "Grid Photo/Emoji",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Upload Image"
        },
        {
          "type": "text",
          "id": "emoji_text",
          "label": "Emoji or Text",
          "default": "🐶"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Interactive Photo Grid",
      "blocks": [
        { "type": "grid_item", "settings": { "emoji_text": "🐶" } },
        { "type": "grid_item", "settings": { "emoji_text": "🧸" } },
        { "type": "grid_item", "settings": { "emoji_text": "🐱" } },
        { "type": "grid_item", "settings": { "emoji_text": "🍕" } },
        { "type": "grid_item", "settings": { "emoji_text": "🎉" } }
      ]
    }
  ]
}
{% endschema %}